+"""Tests for the Modality interface and TextModality stub."""
+
+from __future__ import annotations
+
+from multimodal_agent.modality import Modality, TextModality
+
+
+class TestTextModality:
+    def test_capture_returns_configured_text(self):
+        m = TextModality("hello world")
+        assert m.capture() == "hello world"
+
+    def test_capture_empty_string(self):
+        m = TextModality("")
+        assert m.capture() == ""
+
+    def test_capture_is_idempotent(self):
+        """Calling capture() twice should return the same text."""
+        m = TextModality("repeat")
+        assert m.capture() == m.capture()
+
+    def test_text_modality_satisfies_protocol(self):
+        """TextModality must be recognised as a Modality via runtime_checkable."""
+        m = TextModality("x")
+        assert isinstance(m, Modality)
+
+    def test_no_heavy_imports(self):
+        """Importing modality must not pull in whisper, pyttsx3, pillow, or anthropic."""
+        import sys
+
+        for banned in ("whisper", "pyttsx3", "PIL", "anthropic"):
+            assert banned not in sys.modules, (
+                f"Unexpected import of '{banned}' when loading modality module"
+            )
