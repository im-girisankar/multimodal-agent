+"""Speech-to-Text modality using OpenAI Whisper.
+
+Requires the ``audio`` optional dependency group::
+
+    pip install 'multimodal-agent[audio]'
+
+This module performs all heavy imports lazily so that importing the package
+itself (without the extras) never fails.
+"""
+
+from __future__ import annotations
+
+import os
+
+
+class WhisperModality:
+    """Record audio from the microphone and transcribe it via Whisper.
+
+    Parameters
+    ----------
+    model_name:
+        Whisper model identifier (e.g. ``"base"``, ``"small"``, ``"medium"``).
+    audio_path:
+        If provided, transcribe this audio file instead of recording live.
+    """
+
+    def __init__(self, model_name: str = "base", audio_path: str | None = None) -> None:
+        self._model_name = model_name
+        self._audio_path = audio_path
+        self._model = None  # loaded lazily
+
+    def _load_model(self):  # type: ignore[return]
+        """Lazily load the Whisper model."""
+        if self._model is None:
+            try:
+                import whisper  # type: ignore[import]
+            except ImportError as exc:
+                raise ImportError(
+                    "The 'audio' extra is required for WhisperModality.\n"
+                    "Install it with: pip install 'multimodal-agent[audio]'"
+                ) from exc
+            self._model = whisper.load_model(self._model_name)
+        return self._model
+
+    def capture(self) -> str:
+        """Transcribe audio and return the text.
+
+        If *audio_path* was provided at construction, transcribes that file.
+        Otherwise, raises :exc:`NotImplementedError` (live recording requires
+        additional platform dependencies not bundled here).
+        """
+        model = self._load_model()
+        if self._audio_path is None:
+            raise NotImplementedError(
+                "Live microphone capture is not implemented. "
+                "Pass audio_path= to transcribe an existing file."
+            )
+        if not os.path.isfile(self._audio_path):
+            raise FileNotFoundError(f"Audio file not found: {self._audio_path}")
+        result = model.transcribe(self._audio_path)
+        return result.get("text", "").strip()
