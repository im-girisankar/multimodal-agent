+"""Tool registry and built-in demo tools.
+
+Tools are plain callables registered by name.  The agent calls
+``registry.dispatch(tool_call)`` which returns a string observation.
+"""
+
+from __future__ import annotations
+
+import math
+from collections.abc import Callable
+from datetime import datetime, timezone
+from typing import Any
+
+
+class ToolError(Exception):
+    """Raised when a tool is called with invalid arguments or an unknown name."""
+
+
+# A Tool is any callable that accepts keyword arguments and returns a string.
+Tool = Callable[..., str]
+
+
+class ToolRegistry:
+    """Central registry mapping tool names to callables."""
+
+    def __init__(self) -> None:
+        self._tools: dict[str, Tool] = {}
+
+    def register(self, name: str, fn: Tool) -> None:
+        """Register a tool under *name*."""
+        self._tools[name] = fn
+
+    def names(self) -> list[str]:
+        """Return sorted list of registered tool names."""
+        return sorted(self._tools)
+
+    def dispatch(self, name: str, args: dict[str, Any]) -> str:
+        """Call the tool named *name* with *args* and return its string result.
+
+        Raises
+        ------
+        ToolError
+            If *name* is not registered or the tool raises an exception.
+        """
+        if name not in self._tools:
+            raise ToolError(f"Unknown tool: '{name}'. Available: {self.names()}")
+        try:
+            return self._tools[name](**args)
+        except Exception as exc:
+            raise ToolError(f"Tool '{name}' raised {type(exc).__name__}: {exc}") from exc
+
+
+# ---------------------------------------------------------------------------
+# Built-in tools
+# ---------------------------------------------------------------------------
+
+def calculator(a: float, op: str, b: float) -> str:
+    """Evaluate a simple binary arithmetic expression and return the result.
+
+    Parameters
+    ----------
+    a:
+        Left operand.
+    op:
+        One of ``+``, ``-``, ``*``, ``/``, ``**``.
+    b:
+        Right operand.
+    """
+    ops: dict[str, Callable[[float, float], float]] = {
+        "+": lambda x, y: x + y,
+        "-": lambda x, y: x - y,
+        "*": lambda x, y: x * y,
+        "/": lambda x, y: x / y,
+        "**": lambda x, y: x**y,
+    }
+    if op not in ops:
+        raise ValueError(f"Unsupported operator '{op}'. Use one of: {sorted(ops)}")
+    if op == "/" and b == 0:
+        raise ValueError("Division by zero")
+    result = ops[op](a, b)
+    # Return a clean representation (drop trailing ".0" for integers).
+    if isinstance(result, float) and result == math.floor(result):
+        return str(int(result))
+    return str(result)
+
+
+def clock(fmt: str = "%Y-%m-%d %H:%M:%S UTC") -> str:
+    """Return the current UTC time formatted according to *fmt*."""
+    return datetime.now(tz=timezone.utc).strftime(fmt)
+
+
+# ---------------------------------------------------------------------------
+# Default registry (populated at module level â€” no heavy imports required)
+# ---------------------------------------------------------------------------
+
+default_registry = ToolRegistry()
+default_registry.register("calculator", calculator)
+default_registry.register("clock", clock)
